<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DistressedLeads.AI — Find Motivated Sellers</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #E63946;
    --amber: #F4A261;
    --green: #2A9D8F;
    --dark: #0a0a0b;
    --panel: #111114;
    --border: #222228;
    --muted: #555562;
    --text: #e8e8f0;
    --sub: #9090a8;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'IBM Plex Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(230,57,70,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(230,57,70,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .app { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 0 24px 80px; }

  /* HEADER */
  header {
    padding: 32px 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 3px;
    color: var(--red);
  }
  .logo span { color: var(--text); }

  .badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--amber);
    border: 1px solid var(--amber);
    padding: 3px 10px;
    letter-spacing: 2px;
    animation: pulse-border 2s ease infinite;
  }

  @keyframes pulse-border {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* HERO */
  .hero {
    margin-bottom: 40px;
  }
  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 8vw, 88px);
    line-height: 0.95;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .hero h1 em {
    color: var(--red);
    font-style: normal;
    display: block;
  }
  .hero p {
    color: var(--sub);
    font-size: 15px;
    max-width: 520px;
    line-height: 1.7;
  }

  /* FORM */
  .search-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 32px;
    margin-bottom: 36px;
    position: relative;
    overflow: hidden;
  }
  .search-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--red), var(--amber));
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .field input, .field select, .field textarea {
    background: var(--dark);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px 14px;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    border-color: var(--red);
  }
  .field select option { background: #1a1a1e; }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin-bottom: 24px;
  }
  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 8px 12px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .checkbox-item:hover { border-color: var(--red); background: rgba(230,57,70,0.05); }
  .checkbox-item input[type="checkbox"] { accent-color: var(--red); width: 14px; height: 14px; }
  .checkbox-item span {
    font-size: 13px;
    color: var(--sub);
    transition: color 0.2s;
  }
  .checkbox-item:has(input:checked) { border-color: var(--red); background: rgba(230,57,70,0.08); }
  .checkbox-item:has(input:checked) span { color: var(--text); }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 12px;
    margin-top: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .btn-generate {
    width: 100%;
    padding: 16px;
    background: var(--red);
    border: none;
    color: white;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 4px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.2s;
  }
  .btn-generate:hover { background: #c8303c; transform: translateY(-1px); }
  .btn-generate:active { transform: translateY(0); }
  .btn-generate:disabled { background: #4a1a1e; color: var(--muted); cursor: not-allowed; transform: none; }

  .btn-generate .spinner {
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 8px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* RESULTS */
  .results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .results-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
  }
  .results-count {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--amber);
    border: 1px solid var(--amber);
    padding: 4px 12px;
  }

  .leads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .lead-card {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    animation: fadeIn 0.4s ease both;
  }
  .lead-card:hover { border-color: var(--red); transform: translateY(-2px); }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .lead-card .score-bar {
    position: absolute;
    top: 0; left: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--red), var(--amber));
  }

  .lead-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .lead-address {
    font-weight: 600;
    font-size: 14px;
    line-height: 1.4;
    flex: 1;
    margin-right: 12px;
  }
  .lead-address small {
    display: block;
    font-weight: 400;
    color: var(--sub);
    font-size: 12px;
  }

  .distress-score {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    line-height: 1;
  }
  .distress-score small {
    display: block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--muted);
    text-align: center;
  }

  .score-high { color: var(--red); }
  .score-med { color: var(--amber); }
  .score-low { color: var(--green); }

  .lead-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }
  .signal-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    padding: 3px 8px;
    text-transform: uppercase;
  }
  .signal-tag.hot { background: rgba(230,57,70,0.15); color: var(--red); border: 1px solid rgba(230,57,70,0.3); }
  .signal-tag.warm { background: rgba(244,162,97,0.12); color: var(--amber); border: 1px solid rgba(244,162,97,0.3); }
  .signal-tag.cool { background: rgba(42,157,143,0.12); color: var(--green); border: 1px solid rgba(42,157,143,0.3); }

  .lead-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .detail-item { }
  .detail-item .d-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .detail-item .d-value {
    font-size: 13px;
    font-weight: 500;
    margin-top: 2px;
  }

  .lead-summary {
    font-size: 12px;
    color: var(--sub);
    line-height: 1.6;
    margin-bottom: 14px;
    font-style: italic;
  }

  .lead-actions {
    display: flex;
    gap: 8px;
  }
  .btn-sm {
    flex: 1;
    padding: 8px;
    border: 1px solid;
    background: transparent;
    cursor: pointer;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.15s;
  }
  .btn-contact { border-color: var(--red); color: var(--red); }
  .btn-contact:hover { background: var(--red); color: white; }
  .btn-save { border-color: var(--border); color: var(--muted); }
  .btn-save:hover { border-color: var(--sub); color: var(--text); }
  .btn-save.saved { border-color: var(--green); color: var(--green); }

  /* OUTREACH MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--panel);
    border: 1px solid var(--border);
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
  }
  .modal-top {
    position: sticky;
    top: 0;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    padding: 20px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .modal-top h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--amber);
  }
  .btn-close {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 20px;
    padding: 4px 8px;
    transition: color 0.2s;
  }
  .btn-close:hover { color: var(--text); }

  .modal-body { padding: 24px; }

  .outreach-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .tab-btn {
    padding: 10px 16px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: -1px;
    transition: all 0.2s;
  }
  .tab-btn.active { color: var(--amber); border-bottom-color: var(--amber); }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  .outreach-text {
    background: var(--dark);
    border: 1px solid var(--border);
    color: var(--text);
    width: 100%;
    min-height: 200px;
    padding: 16px;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 14px;
    line-height: 1.7;
    resize: vertical;
    outline: none;
  }
  .outreach-text:focus { border-color: var(--amber); }

  .modal-generating {
    text-align: center;
    padding: 40px;
    color: var(--sub);
    font-size: 14px;
    display: none;
  }
  .modal-generating.show { display: block; }
  .modal-generating .big-spinner {
    width: 32px; height: 32px;
    border: 3px solid var(--border);
    border-top-color: var(--amber);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }

  .btn-copy-msg {
    width: 100%;
    margin-top: 12px;
    padding: 12px;
    background: transparent;
    border: 1px solid var(--amber);
    color: var(--amber);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 3px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-copy-msg:hover { background: var(--amber); color: var(--dark); }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    color: var(--muted);
    display: none;
  }
  .empty-state.show { display: block; }
  .empty-state .big-icon {
    font-size: 48px;
    display: block;
    margin-bottom: 16px;
    opacity: 0.4;
  }
  .empty-state p { font-size: 14px; line-height: 1.6; max-width: 360px; margin: 0 auto; }

  /* STATS BAR */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .stat-item {
    background: var(--panel);
    padding: 20px;
    text-align: center;
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--red);
    line-height: 1;
    display: block;
  }
  .stat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* Error */
  .error-msg {
    background: rgba(230,57,70,0.1);
    border: 1px solid rgba(230,57,70,0.3);
    color: var(--red);
    padding: 12px 16px;
    font-size: 13px;
    margin-bottom: 16px;
    display: none;
    font-family: 'IBM Plex Mono', monospace;
  }
  .error-msg.show { display: block; }

  @media (max-width: 640px) {
    .form-grid { grid-template-columns: 1fr; }
    .stats-bar { grid-template-columns: 1fr 1fr; }
    .leads-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 52px; }
  }

  .proxy-banner {
    background: rgba(244,162,97,0.08);
    border: 1px solid rgba(244,162,97,0.25);
    padding: 12px 16px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .proxy-banner input {
    flex: 1;
    background: var(--dark);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 7px 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    outline: none;
    transition: border-color 0.2s;
  }
  .proxy-banner input:focus { border-color: var(--amber); }
  .proxy-banner input::placeholder { color: var(--muted); }
  .proxy-banner label { color: var(--amber); font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 2px; white-space: nowrap; }
  .proxy-dot { width:8px; height:8px; border-radius:50%; background: var(--red); flex-shrink:0; box-shadow: 0 0 6px var(--red); transition: all 0.3s; }
  .proxy-dot.on { background: var(--green); box-shadow: 0 0 8px var(--green); }

</style>
</head>
<body>
<div class="app">

  <header>
    <div class="logo">Distressed<span>Leads</span>.AI</div>
    <div class="badge">⚡ AI POWERED</div>
  </header>

  
  <div class="proxy-banner">
    <div class="proxy-dot" id="proxy-dot"></div>
    <label>PROXY&nbsp;URL</label>
    <input type="text" id="proxy-url" value="https://distressed-leads-proxy.onrender.com" placeholder="https://your-app.railway.app  ← paste your Railway/Render URL here" oninput="updateProxy()" />
  </div>

  <div class="hero">
    <h1>Find <em>Motivated</em> Sellers</h1>
    <p>AI-powered lead intelligence for distressed real estate. Generate targeted seller profiles, distress signals, and ready-to-send outreach in seconds.</p>
  </div>

  <div class="stats-bar">
    <div class="stat-item"><span class="stat-num" id="stat-generated">0</span><span class="stat-label">Leads Generated</span></div>
    <div class="stat-item"><span class="stat-num" id="stat-saved">0</span><span class="stat-label">Saved</span></div>
    <div class="stat-item"><span class="stat-num" id="stat-hot">0</span><span class="stat-label">Hot (80+)</span></div>
    <div class="stat-item"><span class="stat-num" id="stat-msgs">0</span><span class="stat-label">Messages Sent</span></div>
  </div>

  <div class="search-panel">
    <div class="section-label">Search Parameters</div>
    <div class="form-grid">
      <div class="field">
        <label>City / Metro Area</label>
        <input type="text" id="inp-city" placeholder="e.g. Atlanta, GA" />
      </div>
      <div class="field">
        <label>Property Type</label>
        <select id="inp-type">
          <option value="Any">Any Type</option>
          <option value="Single Family">Single Family</option>
          <option value="Multi-Family">Multi-Family</option>
          <option value="Condo/Townhome">Condo / Townhome</option>
          <option value="Commercial">Commercial</option>
          <option value="Land/Lot">Land / Lot</option>
        </select>
      </div>
      <div class="field">
        <label>Price Range</label>
        <select id="inp-price">
          <option value="Any">Any Price</option>
          <option value="Under $100K">Under $100K</option>
          <option value="$100K–$250K">$100K – $250K</option>
          <option value="$250K–$500K">$250K – $500K</option>
          <option value="$500K–$1M">$500K – $1M</option>
          <option value="$1M+">$1M+</option>
        </select>
      </div>
    </div>

    <div class="section-label">Distress Signals to Target</div>
    <div class="checkbox-grid" id="signal-checks">
      <label class="checkbox-item"><input type="checkbox" value="Pre-Foreclosure" checked><span>Pre-Foreclosure</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Tax Delinquent" checked><span>Tax Delinquent</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Probate/Estate" checked><span>Probate / Estate</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Divorce Filing"><span>Divorce Filing</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Code Violations"><span>Code Violations</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Vacant Property"><span>Vacant Property</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Absentee Owner"><span>Absentee Owner</span></label>
      <label class="checkbox-item"><input type="checkbox" value="High Equity"><span>High Equity</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Long-term Owner"><span>Long-term Owner (10+ yrs)</span></label>
      <label class="checkbox-item"><input type="checkbox" value="Failed Listing"><span>Failed / Expired Listing</span></label>
    </div>

    <div class="form-grid">
      <div class="field">
        <label>Number of Leads</label>
        <select id="inp-count">
          <option value="3">3 leads</option>
          <option value="5" selected>5 leads</option>
          <option value="8">8 leads</option>
          <option value="10">10 leads</option>
        </select>
      </div>
      <div class="field">
        <label>Min. Distress Score</label>
        <select id="inp-minscore">
          <option value="Any">Any score</option>
          <option value="50">50+ (Moderate)</option>
          <option value="70">70+ (High)</option>
          <option value="85">85+ (Critical)</option>
        </select>
      </div>
      <div class="field">
        <label>Investor Strategy</label>
        <select id="inp-strategy">
          <option value="Wholesale">Wholesale</option>
          <option value="Fix & Flip">Fix & Flip</option>
          <option value="Buy & Hold">Buy & Hold</option>
          <option value="Subject-To">Subject-To</option>
          <option value="Seller Finance">Seller Finance</option>
        </select>
      </div>
    </div>

    <div class="error-msg" id="error-msg">⚠ Please fill in a city/metro area to search.</div>

    <button class="btn-generate" id="btn-gen" onclick="generateLeads()">
      FIND DISTRESSED LEADS
    </button>
  </div>

  <!-- Results -->
  <div id="results-section" style="display:none">
    <div class="results-header">
      <div class="results-title">LEADS FOUND</div>
      <div class="results-count" id="results-count">0 RESULTS</div>
    </div>
    <div class="leads-grid" id="leads-grid"></div>
  </div>

  <div class="empty-state" id="empty-state">
    <span class="big-icon">🏚</span>
    <p>Configure your search parameters and click <strong>Find Distressed Leads</strong> to generate AI-powered motivated seller leads.</p>
  </div>
</div>

<!-- Outreach Modal -->
<div class="modal-overlay" id="modal-overlay" onclick="handleOverlayClick(event)">
  <div class="modal">
    <div class="modal-top">
      <h3>OUTREACH GENERATOR</h3>
      <button class="btn-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div id="modal-lead-info" style="margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid var(--border);"></div>

      <div class="modal-generating" id="modal-loading">
        <div class="big-spinner"></div>
        Generating personalized outreach messages...
      </div>

      <div id="modal-content" style="display:none">
        <div class="outreach-tabs">
          <button class="tab-btn active" onclick="switchTab('sms')">SMS Text</button>
          <button class="tab-btn" onclick="switchTab('letter')">Direct Mail</button>
          <button class="tab-btn" onclick="switchTab('cold')">Cold Call Script</button>
        </div>
        <div class="tab-content active" id="tab-sms">
          <textarea class="outreach-text" id="msg-sms"></textarea>
          <button class="btn-copy-msg" onclick="copyMsg('sms')">COPY SMS MESSAGE</button>
        </div>
        <div class="tab-content" id="tab-letter">
          <textarea class="outreach-text" id="msg-letter" style="min-height:280px"></textarea>
          <button class="btn-copy-msg" onclick="copyMsg('letter')">COPY LETTER</button>
        </div>
        <div class="tab-content" id="tab-cold">
          <textarea class="outreach-text" id="msg-cold" style="min-height:260px"></textarea>
          <button class="btn-copy-msg" onclick="copyMsg('cold')">COPY SCRIPT</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>

  let PROXY_BASE = 'https://distressed-leads-proxy.onrender.com';
  function updateProxy() {
    const val = document.getElementById('proxy-url').value.trim().replace(/\/+$/, '');
    PROXY_BASE = val;
    const dot = document.getElementById('proxy-dot');
    if (val.startsWith('http')) { dot.classList.add('on'); } 
    else { dot.classList.remove('on'); }
  }

  let allLeads = [];
  let savedLeads = new Set();
  let msgsSent = 0;
  let currentLead = null;

  function getSignals() {
    return Array.from(document.querySelectorAll('#signal-checks input:checked')).map(cb => cb.value);
  }

  function scoreColor(s) {
    if (s >= 80) return 'score-high';
    if (s >= 60) return 'score-med';
    return 'score-low';
  }

  async function generateLeads() {
    const city = document.getElementById('inp-city').value.trim();
    const type = document.getElementById('inp-type').value;
    const price = document.getElementById('inp-price').value;
    const count = parseInt(document.getElementById('inp-count').value);
    const minScore = document.getElementById('inp-minscore').value;
    const strategy = document.getElementById('inp-strategy').value;
    const signals = getSignals();

    const errEl = document.getElementById('error-msg');
    if (!city) { errEl.classList.add('show'); return; }
    errEl.classList.remove('show');

    const btn = document.getElementById('btn-gen');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span>ANALYZING MARKET DATA...';

    document.getElementById('empty-state').classList.remove('show');
    document.getElementById('results-section').style.display = 'none';

    const prompt = `You are a real estate data intelligence AI. Generate ${count} realistic distressed property seller leads for the area: ${city}.

Parameters:
- Property Type: ${type}
- Price Range: ${price}
- Distress Signals: ${signals.join(', ')}
- Min Distress Score: ${minScore}
- Investor Strategy: ${strategy}

Return ONLY a JSON array (no markdown, no explanation) with this exact structure:
[
  {
    "address": "123 Main St",
    "city": "${city}",
    "propType": "Single Family",
    "beds": 3,
    "baths": 2,
    "sqft": 1450,
    "estValue": "$187,000",
    "ownerName": "John Doe",
    "yearsOwned": 14,
    "signals": ["Pre-Foreclosure", "Tax Delinquent"],
    "distressScore": 88,
    "arv": "$210,000",
    "estRepairs": "$22,000",
    "summary": "Owner appears highly motivated. Behind 3 months on taxes with lis pendens filed. Property showing deferred maintenance."
  }
]

Make addresses, names, values realistic for ${city}. Vary distress scores. Signals must be from: ${signals.join(', ')}. Each lead should have 1-4 signals. Distress score 1-99.`;

    try {
      const res = await fetch(PROXY_BASE + '/api/claude', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 2000,
          messages: [{ role: 'user', content: prompt }]
        })
      });

      const data = await res.json();
      const text = data.content.map(b => b.text || '').join('');
      const cleaned = text.replace(/```json|```/g, '').trim();
      const leads = JSON.parse(cleaned);

      allLeads = leads;
      renderLeads(leads);

      // Update stats
      document.getElementById('stat-generated').textContent = parseInt(document.getElementById('stat-generated').textContent) + leads.length;
      document.getElementById('stat-hot').textContent = allLeads.filter(l => l.distressScore >= 80).length;

    } catch (e) {
      document.getElementById('error-msg').textContent = '⚠ Failed to generate leads. Please try again.';
      document.getElementById('error-msg').classList.add('show');
    }

    btn.disabled = false;
    btn.innerHTML = 'FIND DISTRESSED LEADS';
  }

  function renderLeads(leads) {
    const grid = document.getElementById('leads-grid');
    const section = document.getElementById('results-section');

    grid.innerHTML = '';
    section.style.display = 'block';
    document.getElementById('results-count').textContent = leads.length + ' RESULTS';

    leads.forEach((lead, i) => {
      const sc = lead.distressScore;
      const scClass = scoreColor(sc);
      const scoreWidth = sc + '%';
      const isSaved = savedLeads.has(i);

      const signalTags = lead.signals.map(s => {
        const cls = sc >= 80 ? 'hot' : sc >= 60 ? 'warm' : 'cool';
        return `<span class="signal-tag ${cls}">${s}</span>`;
      }).join('');

      const card = document.createElement('div');
      card.className = 'lead-card';
      card.style.animationDelay = (i * 0.07) + 's';
      card.innerHTML = `
        <div class="score-bar" style="width:${scoreWidth}"></div>
        <div class="lead-card-top">
          <div class="lead-address">
            ${lead.address}
            <small>${lead.city}</small>
          </div>
          <div class="distress-score ${scClass}">
            ${sc}
            <small>DISTRESS</small>
          </div>
        </div>
        <div class="lead-signals">${signalTags}</div>
        <div class="lead-details">
          <div class="detail-item">
            <div class="d-label">Owner</div>
            <div class="d-value">${lead.ownerName}</div>
          </div>
          <div class="detail-item">
            <div class="d-label">Property Type</div>
            <div class="d-value">${lead.propType}</div>
          </div>
          <div class="detail-item">
            <div class="d-label">Est. Value</div>
            <div class="d-value">${lead.estValue}</div>
          </div>
          <div class="detail-item">
            <div class="d-label">Size</div>
            <div class="d-value">${lead.beds}bd / ${lead.baths}ba · ${lead.sqft?.toLocaleString()} sqft</div>
          </div>
          <div class="detail-item">
            <div class="d-label">ARV</div>
            <div class="d-value">${lead.arv}</div>
          </div>
          <div class="detail-item">
            <div class="d-label">Est. Repairs</div>
            <div class="d-value">${lead.estRepairs}</div>
          </div>
        </div>
        <div class="lead-summary">"${lead.summary}"</div>
        <div class="lead-actions">
          <button class="btn-sm btn-contact" onclick="openOutreach(${i})">✉ GENERATE OUTREACH</button>
          <button class="btn-sm btn-save ${isSaved ? 'saved' : ''}" id="save-btn-${i}" onclick="toggleSave(${i})">
            ${isSaved ? '★ SAVED' : '☆ SAVE'}
          </button>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  function toggleSave(i) {
    const btn = document.getElementById('save-btn-' + i);
    if (savedLeads.has(i)) {
      savedLeads.delete(i);
      btn.classList.remove('saved');
      btn.textContent = '☆ SAVE';
    } else {
      savedLeads.add(i);
      btn.classList.add('saved');
      btn.textContent = '★ SAVED';
    }
    document.getElementById('stat-saved').textContent = savedLeads.size;
  }

  async function openOutreach(i) {
    currentLead = allLeads[i];
    const overlay = document.getElementById('modal-overlay');
    const loading = document.getElementById('modal-loading');
    const content = document.getElementById('modal-content');
    const info = document.getElementById('modal-lead-info');

    info.innerHTML = `
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <div style="font-weight:600;font-size:15px;">${currentLead.address}</div>
          <div style="color:var(--sub);font-size:12px;margin-top:2px;">${currentLead.city} · ${currentLead.propType} · Owner: ${currentLead.ownerName}</div>
          <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
            ${currentLead.signals.map(s => `<span class="signal-tag hot">${s}</span>`).join('')}
          </div>
        </div>
        <div class="distress-score ${scoreColor(currentLead.distressScore)}" style="font-size:28px">
          ${currentLead.distressScore}<small>SCORE</small>
        </div>
      </div>
    `;

    overlay.classList.add('open');
    loading.classList.add('show');
    content.style.display = 'none';

    const strategy = document.getElementById('inp-strategy').value;

    const prompt = `You are an expert real estate investor outreach copywriter specializing in distressed property acquisitions.

Lead Details:
- Owner: ${currentLead.ownerName}
- Property: ${currentLead.address}, ${currentLead.city}
- Type: ${currentLead.propType} (${currentLead.beds}bd/${currentLead.baths}ba, ${currentLead.sqft} sqft)
- Estimated Value: ${currentLead.estValue}
- Distress Signals: ${currentLead.signals.join(', ')}
- Investor Strategy: ${strategy}
- Situation: ${currentLead.summary}

Generate 3 personalized outreach messages. Return ONLY JSON (no markdown):
{
  "sms": "A short, empathetic 2-3 sentence SMS text (under 160 chars ideally). Non-pushy. Reference their situation subtly.",
  "letter": "A warm 3-paragraph direct mail letter. Paragraph 1: Empathy/intro. Paragraph 2: How you can help. Paragraph 3: CTA with contact info placeholder [YOUR PHONE]. Sign as [YOUR NAME], Local Real Estate Investor.",
  "cold": "A 4-part cold call script: Opening (10 sec), Discovery question, Value proposition for their ${strategy} situation, and Soft close. Format with labels: OPENING:, DISCOVERY:, VALUE:, CLOSE:"
}`;

    try {
      const res = await fetch(PROXY_BASE + '/api/claude', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1200,
          messages: [{ role: 'user', content: prompt }]
        })
      });
      const data = await res.json();
      const text = data.content.map(b => b.text || '').join('');
      const cleaned = text.replace(/```json|```/g, '').trim();
      const msgs = JSON.parse(cleaned);

      document.getElementById('msg-sms').value = msgs.sms;
      document.getElementById('msg-letter').value = msgs.letter;
      document.getElementById('msg-cold').value = msgs.cold;

      loading.classList.remove('show');
      content.style.display = 'block';

      // Switch to first tab
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector('.tab-btn').classList.add('active');
      document.getElementById('tab-sms').classList.add('active');

    } catch (e) {
      loading.innerHTML = '<div style="color:var(--red)">⚠ Failed to generate messages. Please try again.</div>';
    }
  }

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
  }
  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
  }

  function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    const idx = ['sms','letter','cold'].indexOf(tab);
    document.querySelectorAll('.tab-btn')[idx].classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
  }

  function copyMsg(type) {
    const el = document.getElementById('msg-' + type);
    navigator.clipboard.writeText(el.value).then(() => {
      msgsSent++;
      document.getElementById('stat-msgs').textContent = msgsSent;
    });
  }

  // Show empty state on load
  document.getElementById('empty-state').classList.add('show');
</script>
</body>
</html>
